{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run generate:sitemap",
    "build:prerender": "vite build && react-snap",
    "build:mac": "vite build && PUPPETEER_EXECUTABLE_PATH=\"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome\" react-snap",
    "postinstall": "patch-package",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "dompurify": "^3.3.3",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "nodemailer": "^6.9.12",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intersection-observer": "^9.8.1",
    "react-markdown": "^9.0.1",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.22.3",
    "react-table": "^7.8.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-table": "^7.7.19",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.35",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  },
  "reactSnap": {
    "source": "dist",
    "crawl": false,
    "concurrency": 2,
    "include": [
      "/",
      "/about",
      "/colleges",
      "/success-stories",
      "/testimonials",
      "/blog",
      "/privacy-policy",
      "/terms"
    ],
    "skipThirdPartyRequests": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ]
  }
}
